  <GVL Name="gPersistent" Id="{6322c936-6592-448e-b025-6c0c82f2c14b}">
    <Declaration><![CDATA[{attribute 'qualified_only'}
{attribute 'Tc2GvlVarNames'}
VAR_GLOBAL PERSISTENT

