	bDisablePackerQueueAlarm		: BOOL;

	sLastFileNameToDlogHMI			: T_CAC_Filename;	(*READ/WRITE BY HMI ONLY*)
	sLastFileTimeToDlogHMI			: STRING(19);		(*READ/WRITE BY HMI ONLY*)

	nStackIndexDebug				: ARRAY[0..10] OF UDINT;
	
	nRecoverOuterLable				: INT;

	(*sHMICaseStats				 	: ST_SCANNER_Statistics;*)

(*	fbShiftPackMonitor	: FB_KPI_ChangeItemsProducedTrig;
	fbShiftOuterMonitor	: FB_KPI_ChangeItemsProducedTrig;
	fbShiftCaseMonitor	: FB_KPI_ChangeItemsProducedTrig;
	fbProdPackMonitor	: FB_KPI_ChangeItemsProducedTrig;
	fbProdOuterMonitor	: FB_KPI_ChangeItemsProducedTrig;
	fbProdCaseMonitor	: FB_KPI_ChangeItemsProducedTrig;*)

