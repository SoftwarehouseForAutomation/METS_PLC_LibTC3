	bTPDMonitorEthernet			: BOOL := FALSE;
	bEUCAAirConditionExist		: BOOL := FALSE;
	bTPDAirConditionExist		: BOOL := FALSE;

	(*sCameraPack				: ARRAY[1..6] OF ST_SCANNER; 	(*PACK AGGREGATION OR INTERMEDIAT CAMERAs*)*)

	bUseMultipleOuterFormats		: BOOL := FALSE;
	bInfeedRejectFitted				: BOOL;

	bCaseValidationOverTime 		: BOOL;
END_VAR
]]></Declaration>
