    <Action Name="ResulMockup" Id="{8c8cd8da-3400-4252-ba12-807f6f8a7f1e}">
      <Implementation>
        <ST><![CDATA[IF stEventDataUT.nImageByte < SIZEOF(sResultMessage) THEN
	MEMMOVE(ADR(sResultMessage), ADR(stEventDataUT.aDataLogImage), stEventDataUT.nImageByte);
END_IF
]]></ST>
      </Implementation>
    </Action>
    <Action Name="StructMockup" Id="{2e2d3edf-0830-4130-b72d-13c360e6d388}">
      <Implementation>
        <ST><![CDATA[
stEventDataUT.bEnable := TRUE;
stEventDataUT.sTimeStamp :=MID( F_SYSTEM_SystemTimeAsISO8601(stSystemTime, sUTCTimeZone ), 12, 12);

sLogMessage := '$01ST=53;$02CT=10;DS=GZDNP5JOA3IL;OG=3;XP=-50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=1;$03
					$01ST=53;$02CT=10;DS=N7E1Y89UNK3O;OG=3;XP=-50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=2;$03
					$01ST=53;$02CT=10;DS=JHWJXYFNX9DS;OG=3;XP=50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=3;$03
					$01ST=53;$02CT=10;DS=XGBEZLBV8A9I;OG=3;XP=50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=4;$03';]]></ST>
