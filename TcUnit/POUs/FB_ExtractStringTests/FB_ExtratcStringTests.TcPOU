  <POU Name="FB_ExtratcStringTests" Id="{0eeb4b53-2a6a-4189-8f87-2cbb0bd89f55}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ExtratcStringTests EXTENDS FB_TestSuite

]]></Declaration>
    <Implementation>
      <ST><![CDATA[//==============================================================
//MAIN TESTS
//==============================================================

//fbExtracStringTests_bExtractDataSetFalse_ExtractedDSWtihExtraChar();
//fbExtracStringTests_bExtractDataSetFalse_ExtractedDSAndOGWtihExtraChar();

//fbExtracStringTests_bExtractDataSetTrue_ExtractedDSWtihoutExtraChar();
