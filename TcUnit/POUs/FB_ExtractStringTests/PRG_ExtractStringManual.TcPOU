  <POU Name="PRG_ExtractStringManual" Id="{62954b76-d66f-46c8-a521-cdf54dd6f8da}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM PRG_ExtractStringManual
VAR
	fbExtractString		: EXTRACT.FB_ExtractString;
	
	bExtractData		: BOOL;			(* set TRUE to remove prefix and suffix from strData *)
	nExtractChars		: UINT;			(* if suffix is blank, number of data chars to extract *)
	sPrefix				: T_MaxString;	(* prefix string *)
	sSuffix				: T_MaxString;	(* suffix string *)


	sDataString			: T_MaxString;	(* string to be searched *)

	bStringFound				: BOOL;			(* TRUE = sub-string with matching prefix/suffix found *)
	sExtractedString			: T_MaxString;	(* extracted data *)
	nExtractedStringPos			: UDINT;			(* start pos of extracted string in strString *)

	sResultString			: T_MaxString;	(* extracted data *)
END_VAR
]]></Declaration>
