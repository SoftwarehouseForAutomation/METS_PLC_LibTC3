<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="F_AssignValToStringWithPrefixTests" Id="{750434a9-9021-4dec-a624-43efc4fc2a12}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK F_AssignValToStringWithPrefixTests EXTENDS TcUnit.FB_TestSuite

VAR
	
	asRejectReason		: T_MaxString;
	anValue				: ARRAY[0..10] OF STRING(10);
	asPointer          	: ARRAY[0..10] OF STRING(10);
	nPrefixSize			: UINT;
	nPrefixValue		: STRING(5);
	
	nDuplicateOuter1_Position	: INT;
	nDuplicateOuter2_Position	: INT;
	
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[

//==============================================================
//01.
//==============================================================
DupError01_PrefixSize2Value0();
DupError02_PrefixSize3ValueChar();

//==============================================================
//02.
//==============================================================
INVError01_PrefixSize2Value0();
INVError02_PrefixSize3ValueChar();

//==============================================================
//03.
//==============================================================
VALError01_PrefixSize2Value0();
VALError02_PrefixSize3ValueChar();

//==============================================================
//04.
//==============================================================
OACError01_PrefixSize2Value0();
OACError02_PrefixSize3ValueChar();

//==============================================================
//05.
//==============================================================
OuterSerialError01_PrefixSize2Value0();
OuterSerialError01_PrefixSize3ValueChar();

//==============================================================
//06.
//==============================================================
OuterRSKUError01_PrefixSize2Value0();
OuterRSKUError02_PrefixSize3ValueChar();

//==============================================================
//07.
//==============================================================
OuterBrandError01_PrefixSize2Value0();
OuterBrandError02_PrefixSize3ValueChar();

//==============================================================
//08.
//==============================================================
OuterGTINError01_PrefixSize2Valu0();
OuterGTINError02_PrefixSize3ValuChar();

//==============================================================
//09.
//==============================================================
PackNotLinedError01_PrefixSize2Value0();
PackNotLinedError02_PrefixSize3ValueChar();

//==============================================================
//10.
//==============================================================
RandomError01();
RandomError02();]]></ST>
    </Implementation>
    <Folder Name="01.DUPError" Id="{812bf754-e3c5-408f-9c73-395d15b4ce6f}" />
    <Folder Name="02.INVError" Id="{a54975da-a874-4b19-b9e2-8154e6003d34}" />
    <Folder Name="03.VALError" Id="{318a5d30-3b1d-4d6d-bf47-040e36ce04bf}" />
