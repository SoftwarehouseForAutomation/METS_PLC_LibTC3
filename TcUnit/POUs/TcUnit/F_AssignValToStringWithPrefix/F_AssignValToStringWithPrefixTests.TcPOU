    <Method Name="DupError01_PrefixSize2Value0" Id="{5fb34123-d7cd-4077-b67f-fe12db59e6d2}" FolderPath="01.DUPError\">
      <Declaration><![CDATA[METHOD INTERNAL DupError01_PrefixSize2Value0
VAR
	
	sF_AssignValToStringWithPrefix 		: T_MaxString;
	
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Data init
//from FB_CASE_DuplicatCheck - outer duplicate
asRejectReason := 'XXDUPn1-n2XX';
nPrefixSize	 := 2;
nPrefixValue := '0' ;
asPointer[0] := 'n1';
asPointer[1] := 'n2';

TestInit(nDuplicateOuter1_Position := 2, nDuplicateOuter2_Position := 32);

//Change some data for test scenario below



	
IF TcUnit.TEST_ORDERED('DupError01_PrefixSize2Value0') THEN

	sF_AssignValToStringWithPrefix := CODE.F_AssignValToStringWithPrefix(asRejectReason, anValue,  asPointer, nPrefixSize, nPrefixValue);
	
	AssertEquals_STRING(Expected:= 'XXDUP02-32XX', 
						Actual:= TO_STRING(sF_AssignValToStringWithPrefix), 
						Message:= 'Wrong String written');						

TEST_FINISHED();

END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="DupError02_PrefixSize3ValueChar" Id="{430ecb1e-c6c5-42be-8827-f4906cc6a53c}" FolderPath="01.DUPError\">
      <Declaration><![CDATA[METHOD INTERNAL DupError02_PrefixSize3ValueChar
VAR
	
	sF_AssignValToStringWithPrefix 		: T_MaxString;
	
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Data init
//from FB_CASE_DuplicatCheck - outer duplicate
asRejectReason := 'XXDUPn1-n2XX';
nPrefixSize	 := 3;
nPrefixValue := '#' ;
asPointer[0] := 'n1';
asPointer[1] := 'n2';

TestInit(nDuplicateOuter1_Position := 1, nDuplicateOuter2_Position := 2);

//Change some data for test scenario below



	
IF TcUnit.TEST_ORDERED('DupError02_PrefixSize3ValueChar') THEN

	sF_AssignValToStringWithPrefix := CODE.F_AssignValToStringWithPrefix(asRejectReason, anValue,  asPointer, nPrefixSize, nPrefixValue);
	
	AssertEquals_STRING(Expected:= 'XXDUP#01-#02XX', 
						Actual:= TO_STRING(sF_AssignValToStringWithPrefix), 
						Message:= 'Wrong String written');						

TEST_FINISHED();

END_IF;]]></ST>
      </Implementation>
    </Method>
