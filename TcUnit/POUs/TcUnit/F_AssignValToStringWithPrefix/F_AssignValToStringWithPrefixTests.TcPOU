    <Method Name="RandomError01" Id="{2d4e4341-dc47-4893-a0a4-bf41cb1586e4}" FolderPath="10.Random\">
      <Declaration><![CDATA[METHOD INTERNAL RandomError01
VAR
	
	sF_AssignValToStringWithPrefix 		: T_MaxString;
	
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Data init
//from FB_CASE_DuplicatCheck - outer duplicate
asRejectReason := 'LeFT_X1-Y2_RightY1';
nPrefixSize	 := 3;
nPrefixValue := 'C' ;
asPointer[0] := 'X1';
asPointer[1] := 'Y2';

TestInit(nDuplicateOuter1_Position := 2, nDuplicateOuter2_Position := 6);

//Change some data for test scenario below



	
IF TcUnit.TEST_ORDERED('RandomError01') THEN

	sF_AssignValToStringWithPrefix := CODE.F_AssignValToStringWithPrefix(asRejectReason, anValue,  asPointer, nPrefixSize, nPrefixValue);
	
	AssertEquals_STRING(Expected:= 'LeFT_C02-C06_RightY1', 
						Actual:= TO_STRING(sF_AssignValToStringWithPrefix), 
						Message:= 'Wrong String written');						

TEST_FINISHED();

END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="RandomError02" Id="{6c307e14-c411-4ef1-a89d-598757acfd61}" FolderPath="10.Random\">
      <Declaration><![CDATA[METHOD INTERNAL RandomError02
VAR
	
	sF_AssignValToStringWithPrefix 		: T_MaxString;
	
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[
// Data init
asRejectReason := 'LfT_CY/YZ_RghT';
nPrefixSize	 := 4;
nPrefixValue := 'Cd' ;
asPointer[0] := 'CY';
asPointer[1] := 'YZ';

TestInit(nDuplicateOuter1_Position := 12, nDuplicateOuter2_Position := 9);

//Change some data for test scenario below

	
IF TcUnit.TEST_ORDERED('RandomError02') THEN

	sF_AssignValToStringWithPrefix := CODE.F_AssignValToStringWithPrefix(asRejectReason, anValue,  asPointer, nPrefixSize, nPrefixValue);
	
	AssertEquals_STRING(Expected:= 'LfT_CC12/CC09_RghT', 
						Actual:= TO_STRING(sF_AssignValToStringWithPrefix), 
						Message:= 'Wrong String written');						

TEST_FINISHED();

END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestInit" Id="{dfd8b0e3-554c-4bb1-accb-7f0188c9e60c}">
      <Declaration><![CDATA[METHOD PRIVATE TestInit
VAR_INPUT
	nDuplicateOuter1_Position	: INT;
	nDuplicateOuter2_Position	: INT;
END_VAR

VAR	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
anValue[0] := 	F_StringAddPrefix(INT_TO_STRING(nDuplicateOuter1_Position),2,'0');
anValue[1] := 	F_StringAddPrefix(INT_TO_STRING(nDuplicateOuter2_Position),2,'0');]]></ST>
      </Implementation>
    </Method>
    <Method Name="VALError01_PrefixSize2Value0" Id="{1efa12e9-bf5e-4562-9ad9-d205d27cbfa3}" FolderPath="03.VALError\">
      <Declaration><![CDATA[METHOD INTERNAL VALError01_PrefixSize2Value0
VAR
	
	sF_AssignValToStringWithPrefix 		: T_MaxString;
	
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Data init
asRejectReason := 'XXVALnnXX';
nPrefixSize	 := 2;
nPrefixValue := '0' ;
asPointer[0] := 'nn';
anValue[0]	 := INT_TO_STRING(3);


//Change some data for test scenario below



	
IF TcUnit.TEST_ORDERED('VALError01_PrefixSize2Value0') THEN

	sF_AssignValToStringWithPrefix := CODE.F_AssignValToStringWithPrefix(asRejectReason, anValue,  asPointer, nPrefixSize, nPrefixValue);
	
	AssertEquals_STRING(Expected:= 'XXVAL03XX', 
						Actual:= TO_STRING(sF_AssignValToStringWithPrefix), 
						Message:= 'Wrong String written');						

TEST_FINISHED();

END_IF;]]></ST>
      </Implementation>
    </Method>
    <Method Name="VALError02_PrefixSize3ValueChar" Id="{f672a9c1-19bf-4194-b3b1-84f8ac3d7150}" FolderPath="03.VALError\">
      <Declaration><![CDATA[METHOD INTERNAL VALError02_PrefixSize3ValueChar
VAR
	
	sF_AssignValToStringWithPrefix 		: T_MaxString;
	
	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Data init
asRejectReason := 'XXVALnnXX';
nPrefixSize	 := 3;
nPrefixValue := '%' ;
asPointer[0] := 'nn';
anValue[0]	 := INT_TO_STRING(49);


//Change some data for test scenario below



	
IF TcUnit.TEST_ORDERED('VALError02_PrefixSize3ValueChar') THEN

	sF_AssignValToStringWithPrefix := CODE.F_AssignValToStringWithPrefix(asRejectReason, anValue,  asPointer, nPrefixSize, nPrefixValue);
	
	AssertEquals_STRING(Expected:= 'XXVAL%49XX', 
						Actual:= TO_STRING(sF_AssignValToStringWithPrefix), 
						Message:= 'Wrong String written');						

TEST_FINISHED();

END_IF;]]></ST>
