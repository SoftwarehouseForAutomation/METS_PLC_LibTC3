<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="F_GetItemAITests" Id="{18f97de6-ed76-44ae-ba5e-7b2d44347ddb}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK F_GetItemAITests EXTENDS TcUnit.FB_TestSuite

VAR
	
	(* In/Out test*)		
	
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[

//==============================================================
//01.CASE_Code
//==============================================================
Case_code01_GTIN_extractedWrong();
Case_code02_SERIAL_extractedWrong();
Case_code03_RSKU_extractedWrong();
Case_code04_BATCH_extractedWrong();
Case_code05_PO_extractedWrong();

//Validation method NO 2//
Case_code06_GTIN_VAL2_extractedWrong();

//==============================================================
//02.Outer_Code
//==============================================================
Outer_code01_GTIN_extractedWrong();
Outer_code02_SERIAL_extractedWrong();
Outer_code03_RSKU_extractedWrong();

//==============================================================
//03.Pack_Code
//==============================================================
Pack_code01_SERIAL_extractedWrong();]]></ST>
    </Implementation>
    <Folder Name="01.CASE_Code" Id="{eca26ad4-16d4-4352-be9e-83f84f9e1ce9}" />
    <Folder Name="02.Outer_Code" Id="{dd4a5fbd-c64a-4e04-bcc7-ca7e40191a87}" />
    <Folder Name="03.Pack_Code" Id="{fb8c8ea2-fc9f-435d-a625-17fb6da82d8a}" />
    <Method Name="Case_code01_GTIN_extractedWrong" Id="{f0d30fae-952e-4f2f-ac9d-a35fda3e20c7}" FolderPath="01.CASE_Code\">
      <Declaration><![CDATA[METHOD INTERNAL Case_code01_GTIN_extractedWrong
VAR
	sFullCode		: T_MaxString;
	eCodeType		: CODE.E_CodeAI;
	stCodeInfo		: CODE.ST_CodeInfo;
	
	sF_GetItemAI	: T_MaxString;	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Validation data init
stCodeInfo.eCodeType	:= CODE.E_CodeType.E_CASE;
TestInit(eCodeType := eCodeType, sFullCode := sFullcode, stCodeInfo := stCodeInfo);

//Change some data for test scenario below
sFullCode := '(01)17501031711052(21)86174He081137058500(240)10108245(10)86352024(91)5304012';
eCodeType	:= CODE.E_CodeAI.GTIN;


	
TcUnit.TEST('Case_code01_GTIN_extractedWrong');

	sF_GetItemAI := CODE.F_GetItemAI(sFullCode := sFullCode, 
									 eCodeType := eCodeType, 
									 stCodeInfo := stCodeInfo);
	
	AssertEquals_STRING(Expected:= '17501031711052', 
						Actual:= TO_STRING(sF_GetItemAI), 
						Message:= 'Wrong Case GTIN extracted');						

TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
