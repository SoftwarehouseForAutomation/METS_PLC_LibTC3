    </Method>
    <Method Name="TestInit" Id="{4eb8a079-32fd-4185-b10b-fa0b793458cd}">
      <Declaration><![CDATA[METHOD PRIVATE TestInit
VAR_IN_OUT
	eCodeType		: CODE.E_CodeAI;
	stCodeInfo		: CODE.ST_CodeInfo;
	sFullCode		: T_MaxString;
END_VAR

VAR	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
// Case validation recipe
IF stCodeInfo.eCodeType = CODE.E_CodeType.E_CASE THEN

// GTIN 
	stCodeInfo.stGTIN.sStartAI := '(01)';
	stCodeInfo.stGTIN.sEndAI := '(';
	stCodeInfo.stGTIN.nCodeLength := 14;
	stCodeInfo.stGTIN.nCodeStartPos := 0;	
	
// SERIAL	
	stCodeInfo.stSerialCode.sStartAI := '(21)';
	stCodeInfo.stSerialCode.sEndAI := '(';
	stCodeInfo.stSerialCode.nCodeLength := 19;
	stCodeInfo.stSerialCode.nCodeStartPos := 0;	
	
// RSKU
	stCodeInfo.stRSKU.sStartAI := '(240)';
	stCodeInfo.stRSKU.sEndAI := '(';
	stCodeInfo.stRSKU.nCodeLength := 8;
	stCodeInfo.stRSKU.nCodeStartPos := 0;	
	
// BATCH
	stCodeInfo.stBatchID.sStartAI := '(10)';
	stCodeInfo.stBatchID.sEndAI := '(';
	stCodeInfo.stBatchID.nCodeLength := 8;
	stCodeInfo.stBatchID.nCodeStartPos := 0;	
	
// PRODUCTION ORDER
	stCodeInfo.stProductionOrder.sStartAI := '(91)';
	stCodeInfo.stProductionOrder.sEndAI := '(';
	stCodeInfo.stProductionOrder.nCodeLength := 7;
	stCodeInfo.stProductionOrder.nCodeStartPos := 0;	

stCodeInfo.nMinLength 		:= 10; // NOT used
stCodeInfo.nEntireLength	:= 77;
stCodeInfo.nNumberOfAIs		:= 5;
	
ELSIF stCodeInfo.eCodeType = CODE.E_CodeType.E_OUTER THEN
// GTIN 
	stCodeInfo.stGTIN.sStartAI := '(01)';
	stCodeInfo.stGTIN.sEndAI := '(';
	stCodeInfo.stGTIN.nCodeLength := 14;
	stCodeInfo.stGTIN.nCodeStartPos := 0;	
	
// SERIAL	
	stCodeInfo.stSerialCode.sStartAI := '(21)';
	stCodeInfo.stSerialCode.sEndAI := '(';
	stCodeInfo.stSerialCode.nCodeLength := 19;
	stCodeInfo.stSerialCode.nCodeStartPos := 0;	
	
// RSKU
	stCodeInfo.stRSKU.sStartAI := '(240)';
	stCodeInfo.stRSKU.sEndAI := '';
	stCodeInfo.stRSKU.nCodeLength := 8;
	stCodeInfo.stRSKU.nCodeStartPos := 0;	
	

stCodeInfo.nMinLength 		:= 10; // NOT used
stCodeInfo.nEntireLength	:= 54;
stCodeInfo.nNumberOfAIs		:= 3;

ELSIF stCodeInfo.eCodeType = CODE.E_CodeType.E_PACK THEN
// SERIAL	
	stCodeInfo.stSerialCode.sStartAI := '';
	stCodeInfo.stSerialCode.sEndAI := '';
	stCodeInfo.stSerialCode.nCodeLength := 12;
	stCodeInfo.stSerialCode.nCodeStartPos := 0;	
	
stCodeInfo.nMinLength 		:= 10; // NOT used
stCodeInfo.nEntireLength	:= 12;
stCodeInfo.nNumberOfAIs		:= 0;

END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="TestInitVal_2" Id="{ad80bf69-6243-48f3-8341-22f24cd95c1a}">
      <Declaration><![CDATA[METHOD PRIVATE TestInitVal_2
VAR_IN_OUT
	eCodeType		: CODE.E_CodeAI;
	stCodeInfo		: CODE.ST_CodeInfo;
	sFullCode		: T_MaxString;
END_VAR

VAR	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
// Case validation recipe
IF stCodeInfo.eCodeType = CODE.E_CodeType.E_CASE THEN

// GTIN 
	stCodeInfo.stGTIN.sStartAI := '(01)';
	stCodeInfo.stGTIN.sEndAI := '';
	stCodeInfo.stGTIN.nCodeLength := 10;
	stCodeInfo.stGTIN.nCodeStartPos := 0;	
	
// SERIAL	
	stCodeInfo.stSerialCode.sStartAI := '(21)';
	stCodeInfo.stSerialCode.sEndAI := '(';
	stCodeInfo.stSerialCode.nCodeLength := 19;
	stCodeInfo.stSerialCode.nCodeStartPos := 0;	
	
// RSKU
	stCodeInfo.stRSKU.sStartAI := '(240)';
	stCodeInfo.stRSKU.sEndAI := '(';
	stCodeInfo.stRSKU.nCodeLength := 8;
	stCodeInfo.stRSKU.nCodeStartPos := 0;	
	
// BATCH
	stCodeInfo.stBatchID.sStartAI := '(10)';
	stCodeInfo.stBatchID.sEndAI := '(';
	stCodeInfo.stBatchID.nCodeLength := 8;
	stCodeInfo.stBatchID.nCodeStartPos := 0;	
	
// PRODUCTION ORDER
	stCodeInfo.stProductionOrder.sStartAI := '(91)';
	stCodeInfo.stProductionOrder.sEndAI := '(';
	stCodeInfo.stProductionOrder.nCodeLength := 7;
	stCodeInfo.stProductionOrder.nCodeStartPos := 0;	

stCodeInfo.nMinLength 		:= 10; // NOT used
stCodeInfo.nEntireLength	:= 77;
stCodeInfo.nNumberOfAIs		:= 5;
	
ELSIF stCodeInfo.eCodeType = CODE.E_CodeType.E_OUTER THEN
// GTIN 
	stCodeInfo.stGTIN.sStartAI := '(01)';
	stCodeInfo.stGTIN.sEndAI := '(';
	stCodeInfo.stGTIN.nCodeLength := 14;
	stCodeInfo.stGTIN.nCodeStartPos := 0;	
	
// SERIAL	
	stCodeInfo.stSerialCode.sStartAI := '(21)';
	stCodeInfo.stSerialCode.sEndAI := '(';
	stCodeInfo.stSerialCode.nCodeLength := 19;
	stCodeInfo.stSerialCode.nCodeStartPos := 0;	
	
// RSKU
	stCodeInfo.stRSKU.sStartAI := '(240)';
	stCodeInfo.stRSKU.sEndAI := '';
	stCodeInfo.stRSKU.nCodeLength := 8;
	stCodeInfo.stRSKU.nCodeStartPos := 0;	
	

stCodeInfo.nMinLength 		:= 10; // NOT used
stCodeInfo.nEntireLength	:= 54;
stCodeInfo.nNumberOfAIs		:= 3;

ELSIF stCodeInfo.eCodeType = CODE.E_CodeType.E_PACK THEN
// SERIAL	
	stCodeInfo.stSerialCode.sStartAI := '';
	stCodeInfo.stSerialCode.sEndAI := '';
	stCodeInfo.stSerialCode.nCodeLength := 12;
	stCodeInfo.stSerialCode.nCodeStartPos := 0;	
	
stCodeInfo.nMinLength 		:= 10; // NOT used
stCodeInfo.nEntireLength	:= 12;
stCodeInfo.nNumberOfAIs		:= 0;

END_IF
]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>