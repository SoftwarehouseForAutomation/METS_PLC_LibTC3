    <Method Name="Pack_code01_SERIAL_extractedWrong" Id="{1ede5dd4-b54a-4251-9605-56f61db2c510}" FolderPath="03.Pack_Code\">
      <Declaration><![CDATA[METHOD INTERNAL Pack_code01_SERIAL_extractedWrong
VAR
	sFullCode		: T_MaxString;
	eCodeType		: CODE.E_CodeAI;
	stCodeInfo		: CODE.ST_CodeInfo;
	
	sF_GetItemAI	: T_MaxString;	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[// Validation data init
stCodeInfo.eCodeType	:= CODE.E_CodeType.E_PACK;
TestInit(eCodeType := eCodeType, sFullCode := sFullcode, stCodeInfo := stCodeInfo);

//Change some data for test scenario below
sFullCode := 'BRK8D60ZRJYD';
eCodeType	:= CODE.E_CodeAI.SERIAL;


	
TcUnit.TEST('Pack_code01_SERIAL_extractedWrong');

	sF_GetItemAI := CODE.F_GetItemAI(sFullCode := sFullCode, 
									 eCodeType := eCodeType, 
									 stCodeInfo := stCodeInfo);
	
