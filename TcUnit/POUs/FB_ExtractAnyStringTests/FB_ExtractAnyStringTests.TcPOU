    <Method Name="testNeg04_NoPrefixSufixFoundNoCharsExtr_LeftString" Id="{c0cb3e32-8e8b-4817-8947-6cff0c1a89e7}" FolderPath="02 Negative\">
      <Declaration><![CDATA[METHOD INTERNAL testNeg04_NoPrefixSufixFoundNoCharsExtr_LeftString : REFERENCE TO FB_Test
VAR
	fbSut 			: EXTRACT.FB_ExtractAnyString;
	sResult			: T_LongSTRING;	// Result
	nResult 		: UDINT;	// Result
	nDataResult		: UDINT;
	
	nExtractedOrigin : INT;
	nDataOrigin	: UDINT;
END_VAR
VAR_INST
	sDataString		: T_LongSTRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('testNeg04_NoPrefixSufixFoundNoCharsExtr_LeftString');	
			
sDataString := 'ST=53;$02CT=10;DS=GZDNP5JOA3IL;OG=3;XP=-50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=1;$03$04
					ST=53;$02CT=10;DS=N7E1Y89UNK3O;OG=3;XP=-50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=2;$03$04
					ST=53;$02CT=10;DS=JHWJXYFNX9DS;OG=3;XP=50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=3;$03$04
					ST=53;$02CT=10;DS=XGBEZLBV8A9I;OG=3;XP=50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=4;$03$04'; 

nExtractedOrigin := LEN('ST=53;$02CT=10;DS=GZDNP5JOA3IL;OG=3;XP=-50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=1;$03$04');
nDataOrigin	:= LEN2(ADR(sDataString)) - TO_UDINT(nExtractedOrigin);
					
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:='' , 
	sSuffix:= '$04', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHIDENT, 
	sDataString:= sDataString, 
	bStringFound=> , 
	sExtractedString=>sResult, 
	nExtractedStringPos=> ,
	nExtractedStringLen=>nResult ,
	nDataStringLen=>nDataResult );
	
	AssertEquals_STRING( Expected:= 'ST=53;$02CT=10;DS=GZDNP5JOA3IL;OG=3;XP=-50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=1;$03$04', 
						Actual:= sResult, 
						Message:= 'Extracted string is not as expected');
						
	AssertEquals_UDINT(	Expected:= TO_UDINT(nExtractedOrigin), 
						Actual:= nResult, 
						Message:= 'Extr data in mode:WITHIDENT not as expect');
						
	AssertEquals_UDINT(	Expected:= nDataOrigin, 
						Actual:= nDataResult, 
						Message:= 'Left data in mode:WITHIDENT not as expect');
						
TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="testNeg05_PrefixFoundNoSufixNoCharsExtr_RightString" Id="{6e76e517-f2b1-46c1-8268-102e25e86b0b}" FolderPath="02 Negative\">
      <Declaration><![CDATA[METHOD INTERNAL testNeg05_PrefixFoundNoSufixNoCharsExtr_RightString : REFERENCE TO FB_Test
VAR
	fbSut 			: EXTRACT.FB_ExtractAnyString;
	sResult			: T_LongSTRING;	// Result
	nResult 		: UDINT;	// Result
	nDataResult		: UDINT;
	
	nExtractedOrigin : UDINT;
END_VAR
VAR_INST
	sDataString		: T_LongSTRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('testNeg05_PrefixFoundNoSufixNoCharsExtr_RightString');	
			
sDataString := 'ST=53;$02CT=10;DS=GZDNP5JOA3IL;OG=3;XP=-50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=1;$03$04ST=53;$02CT=10;DS=N7E1Y89UNK3O;OG=3;XP=-50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=2;$03$04
					$01ST=53;$02CT=10;DS=JHWJXYFNX9DS;OG=3;XP=50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=3;$03$04ST=53;$02CT=10;DS=XGBEZLBV8A9I;OG=3;XP=50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=4;$03$04'; 

nExtractedOrigin := LEN2(ADR('$01ST=53;$02CT=10;DS=JHWJXYFNX9DS;OG=3;XP=50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=3;$03$04ST=53;$02CT=10;DS=XGBEZLBV8A9I;OG=3;XP=50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=4;$03$04'));
					
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:='$01' , 
	sSuffix:= '', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHIDENT_PURGE, 
	sDataString:= sDataString, 
	bStringFound=> , 
	sExtractedString=>sResult, 
	nExtractedStringPos=> ,
	nExtractedStringLen=>nResult ,
	nDataStringLen=>nDataResult );
	
	AssertEquals_STRING( Expected:= '$01ST=53;$02CT=10;DS=JHWJXYFNX9DS;OG=3;XP=50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=3;$03$04ST=53;$02CT=10;DS=XGBEZLBV8A9I;OG=3;XP=50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=4;$03$04', 
						Actual:= sResult, 
						Message:= 'Extracted string is not as expected');
						
	AssertEquals_UDINT(	Expected:= TO_UDINT(nExtractedOrigin), 
						Actual:= nResult, 
						Message:= 'Extr data in mode:WITHIDENT_PURGE not as expect');
						
	AssertEquals_UDINT(	Expected:= 0, 
						Actual:= nDataResult, 
						Message:= 'Left data in mode:WITHIDENT_PURGE not as expect');
						
TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="testSeq01_MVxDecode_ImageData" Id="{53331135-41f6-455b-a135-45fa5b5e92c6}" FolderPath="03 Sequence\">
      <Declaration><![CDATA[METHOD INTERNAL testSeq01_MVxDecode_ImageData
VAR
	fbSut01 			: EXTRACT.FB_ExtractAnyString;
	fbSut02 			: EXTRACT.FB_ExtractAnyString;
	fbSut03 			: EXTRACT.FB_ExtractAnyString;
	aResult				: ARRAY[1..3] OF T_LongSTRING;	// Result
	nResult 			: UDINT;	// Result
	nDataResult			: UDINT;
	nIndex				: INT;
	nExtractedOrigin 	: UDINT;
END_VAR				
VAR_INST
	sDataString		: T_LongSTRING;		//'ST=53;$02CT=10;DS=GZDNP5JOA3IL;OG=3;XP=-50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=1;$03'
	stImageData		: ST_SCANNER_ImageData;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('testSeq01_MVxDecode_ImageData');

sDataString := 'ST=53;$02CT=10;DS=GZDNP5JOA3IL;OG=3;XP=-50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=1;$03'; 

	(* get image data message *)
	//fbCodeData
	fbSut01(
		nExtractChars:=0 , 
		sPrefix:='$02' , 
		sSuffix:= '$03', 
		bIgnoreCase:= FALSE, 
		eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_REMIDENT, 
		sDataString:= sDataString, 
		bStringFound=> , 
		sExtractedString=>aResult[1], 
		nExtractedStringPos=> ,
		nExtractedStringLen=> ,
		nDataStringLen=> );
	
		AssertEquals_STRING( Expected:= 'ST=53;', 
						Actual:= sDataString, 
						Message:= 'Extr data in mode:WITHOUTIDENT_REMIDENT not as expect');
						
		AssertEquals_STRING( Expected:= 'CT=10;DS=GZDNP5JOA3IL;OG=3;XP=-50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=1;', 
						Actual:= aResult[1], 
						Message:= 'Extr data in mode:WITHOUTIDENT_REMIDENT not as expect');

	(* code data found *)
	IF fbSut01.bStringFound THEN
		
		nIndex := 1;
		
		//fbFieldData
		fbSut02(
			nExtractChars:=0 , 
			sPrefix:='CT=' , 
			sSuffix:= ';', 
			bIgnoreCase:= FALSE, 
			eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_REMIDENT_PURGE, 
			sDataString:= fbSut01.sExtractedString, 
			bStringFound=> , 
			sExtractedString=>, 
			nExtractedStringPos=> ,
			nExtractedStringLen=> ,
			nDataStringLen=> );
			
		IF fbSut02.bStringFound THEN
			(* extract data value *)
			stImageData.aCodeData[nIndex].eCodeType := STRING_TO_INT(fbSut02.sExtractedString);
		END_IF
		
		AssertEquals_INT(	Expected:= E_SCANNER_CodeType.DATAMARTIX,
					Actual:= stImageData.aCodeData[nIndex].eCodeType, 
					Message:= 'Extr data in mode:WITHOUTIDENT_REMIDENT_PURGE not as expect');
						
		fbSut02(
			nExtractChars:=0 , 
			sPrefix:='DS=' , 
			sSuffix:= ';OG=', 
			bIgnoreCase:= FALSE, 
			eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_PURGE, 
			sDataString:= fbSut01.sExtractedString, 
			bStringFound=> , 
			sExtractedString=>aResult[2], 
			nExtractedStringPos=> ,
			nExtractedStringLen=> ,
			nDataStringLen=> );
		
		IF fbSut02.bStringFound THEN
			(* extract data value *)
			stImageData.aCodeData[nIndex].strDataString := fbSut02.sExtractedString;
		END_IF
		
		AssertEquals_STRING( Expected:= 'GZDNP5JOA3IL', 
				Actual:= aResult[2], 
				Message:= 'Extr data in mode:WITHOUTIDENT_PURGE not as expect');
		
		IF LEN(stImageData.aCodeData[nIndex].strDataString) > 0 AND stImageData.aCodeData[nIndex].eCodeType <> E_SCANNER_CodeType.NONE THEN
			
			fbSut03(
				nExtractChars:=0 , 
				sPrefix:='OG=' , 
				sSuffix:= ';', 
				bIgnoreCase:= FALSE, 
				eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_REMIDENT, 
				sDataString:= fbSut01.sExtractedString, 
				bStringFound=> , 
				sExtractedString=>, 
				nExtractedStringPos=> ,
				nExtractedStringLen=> ,
				nDataStringLen=> );
			
			IF fbSut03.bStringFound THEN
				(* extract data value *)
				stImageData.aCodeData[nIndex].fOverallGrade := STRING_TO_LREAL(fbSut03.sExtractedString);
			END_IF
			
			AssertEquals_LREAL(Expected:= 3, 
						Actual:= stImageData.aCodeData[nIndex].fOverallGrade, 
						Delta:= 0.001, 
						Message:= 'Extr data in mode:WITHOUTIDENT_REMIDENT not as expect' );
			
			fbSut03(
				nExtractChars:=0 , 
				sPrefix:='QS=' , 
				sSuffix:= ';', 
				bIgnoreCase:= FALSE, 
				eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_REMIDENT, 
				sDataString:= fbSut01.sExtractedString, 
				bStringFound=> , 
				sExtractedString=>, 
				nExtractedStringPos=> ,
				nExtractedStringLen=> ,
				nDataStringLen=> );
			
			IF fbSut03.bStringFound THEN
				(* extract data value *)
				stImageData.aCodeData[nIndex].nEvaluation := STRING_TO_INT(fbSut03.sExtractedString);
			END_IF
									
			AssertEquals_INT(	Expected:= 3, 
						Actual:= stImageData.aCodeData[nIndex].nEvaluation, 
						Message:= 'Left data in mode:WITHIDENT_PURGE not as expect');
			
			fbSut03(
				nExtractChars:=0 , 
				sPrefix:='YP=' , 		//XP and YP reversed intetnionally to check if alghoritm is resistant for change order
				sSuffix:= ';', 
				bIgnoreCase:= FALSE, 
				eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_REMIDENT, 
				sDataString:= fbSut01.sExtractedString, 
				bStringFound=> , 
				sExtractedString=>, 
				nExtractedStringPos=> ,
				nExtractedStringLen=> ,
				nDataStringLen=> );
			
			IF fbSut03.bStringFound THEN
				(* extract data value *)
				stImageData.aCodeData[nIndex].fYPos := STRING_TO_LREAL(fbSut03.sExtractedString);
			END_IF
			
			AssertEquals_LREAL(Expected:= 50, 
				Actual:= stImageData.aCodeData[nIndex].fYPos, 
				Delta:= 0.001, 
				Message:= 'Extr data in mode:WITHOUTIDENT_REMIDENT not as expect' );
	
			fbSut03(
				nExtractChars:=0 , 
				sPrefix:='XP=' , 
				sSuffix:= ';', 
				bIgnoreCase:= FALSE, 
				eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_REMIDENT, 
				sDataString:= fbSut01.sExtractedString, 
				bStringFound=> , 
				sExtractedString=>, 
				nExtractedStringPos=> ,
				nExtractedStringLen=> ,
				nDataStringLen=> );
			
			IF fbSut03.bStringFound THEN
				(* extract data value *)
				stImageData.aCodeData[nIndex].fXPos := STRING_TO_LREAL(fbSut03.sExtractedString);
			END_IF
			
			AssertEquals_LREAL(Expected:= -50, 
				Actual:= stImageData.aCodeData[nIndex].fXPos, 
				Delta:= 0.001, 
				Message:= 'Extr data in mode:WITHOUTIDENT_REMIDENT not as expect' );
				
			fbSut03(
				nExtractChars:=0 , 
				sPrefix:='CS=' , 
				sSuffix:= ';', 
				bIgnoreCase:= FALSE, 
				eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_REMIDENT, 
				sDataString:= fbSut01.sExtractedString, 
				bStringFound=> , 
				sExtractedString=>, 
				nExtractedStringPos=> ,
				nExtractedStringLen=> ,
				nDataStringLen=> );
			
			IF fbSut03.bStringFound THEN
				(* extract data value *)
				stImageData.aCodeData[nIndex].fCellSize := STRING_TO_LREAL(fbSut03.sExtractedString);
			END_IF
			
			AssertEquals_LREAL(Expected:= 6.2, 
				Actual:= stImageData.aCodeData[nIndex].fCellSize, 
				Delta:= 0.001, 
				Message:= 'Extr data in mode:WITHOUTIDENT_REMIDENT not as expect' );
				
			fbSut03(
				nExtractChars:=0 , 
				sPrefix:='SC=' , 
				sSuffix:= ';', 
				bIgnoreCase:= FALSE, 
				eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_REMIDENT, 
				sDataString:= fbSut01.sExtractedString, 
				bStringFound=> , 
				sExtractedString=>, 
				nExtractedStringPos=> ,
				nExtractedStringLen=> ,
				nDataStringLen=> );
			
			IF fbSut03.bStringFound THEN
				(* extract data value *)
				stImageData.aCodeData[nIndex].fSymbolContrast := STRING_TO_LREAL(fbSut03.sExtractedString);
			END_IF
			
			AssertEquals_LREAL(Expected:= 70, 
				Actual:= stImageData.aCodeData[nIndex].fSymbolContrast, 
				Delta:= 0.001, 
				Message:= 'Extr data in mode:WITHOUTIDENT_REMIDENT not as expect' );
		END_IF
		
		fbSut02(
			nExtractChars:=0 , 
			sPrefix:='PN=' , 
			sSuffix:= ';', 
			bIgnoreCase:= FALSE, 
			eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_REMIDENT_PURGE, 
			sDataString:= fbSut01.sExtractedString, 
			bStringFound=> , 
			sExtractedString=>, 
			nExtractedStringPos=> ,
			nExtractedStringLen=> ,
			nDataStringLen=> nResult);
		
		IF fbSut02.bStringFound THEN
			(* extract data value *)
			stImageData.aCodeData[nIndex].nProgramNo := STRING_TO_BYTE(fbSut02.sExtractedString);
		END_IF
		
		AssertEquals_BYTE(	Expected:= 1, 
						Actual:= stImageData.aCodeData[nIndex].nProgramNo, 
						Message:= 'Extr data in mode:WITHOUTIDENT_REMIDENT_PURGE not as expect');
						
	END_IF
	
	
	AssertEquals_STRING( Expected:= '',
						Actual:= fbSut01.sExtractedString,
						Message:= 'Extracted string is not as expected');
						
	AssertEquals_UDINT(	Expected:= 0, 
						Actual:= nResult, 
						Message:= 'Extr data in mode:WITHIDENT_PURGE not as expect');

//Check no additional string

	fbSut01(
		nExtractChars:=0 , 
		sPrefix:='$02' , 
		sSuffix:= '$03', 
		bIgnoreCase:= FALSE, 
		eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_REMIDENT, 
		sDataString:= sDataString, 
		bStringFound=> , 
		sExtractedString=>, 
		nExtractedStringPos=> ,
		nExtractedStringLen=>nDataResult ,
		nDataStringLen=> );
	
	AssertEquals_UDINT( Expected:= 0, 
						Actual:= fbSut01.nExtractedStringLen, 
						Message:= 'Extr data in mode:WITHOUTIDENT_REMIDENT not as expect');
						
	(* code data found *)
	IF NOT fbSut01.bStringFound AND nIndex = 1 THEN					
		
		stImageData.nCodesRead	:= nIndex;
		(* Scan Time field (ST=%c;) *)
		fbSut02(
			nExtractChars:=0 , 
			sPrefix:='ST=' , 
			sSuffix:= ';', 
			bIgnoreCase:= FALSE, 
			eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_REMIDENT_PURGE, 
			sDataString:= sDataString, 
			bStringFound=> , 
			sExtractedString=>aResult[3], 
			nExtractedStringPos=> ,
			nExtractedStringLen=> nDataResult,
			nDataStringLen=> );
			
		IF fbSut02.bStringFound THEN
			(* extract data value *)
			stImageData.tScanTime := UDINT_TO_TIME(STRING_TO_UDINT(fbSut02.sExtractedString));
		END_IF
	END_IF
		
	AssertEquals_STRING( Expected:= '', 
					Actual:= sDataString, 
					Message:= 'Extr data in mode:WITHOUTIDENT_REMIDENT_PURGE not as expect');
					
	AssertEquals_TIME( Expected:= T#53MS, 
					Actual:= stImageData.tScanTime, 
					Message:= 'Extr data in mode:WITHOUTIDENT_REMIDENT_PURGE not as expect');

	
	TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>