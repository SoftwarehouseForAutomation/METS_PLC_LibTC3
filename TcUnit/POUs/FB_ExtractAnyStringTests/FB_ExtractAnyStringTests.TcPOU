	sResult 		: T_LongSTRING;	// Result
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('testMain02_ModeWITHIDENTPURGE_ExactDataAndPurge');

fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:='DS=' , 
	sSuffix:= ';OG', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHIDENT_PURGE, 
	sDataString:= sDataString, 
	bStringFound=> , 
	sExtractedString=>sResult, 
	nExtractedStringPos=> ,
	nExtractedStringLen=> ,
	nDataStringLen=> );
	
	
	AssertEquals_STRING(	Expected:= 'DS=]d201062533414058582101485MV125000156300$1D24010120957;OG', 
