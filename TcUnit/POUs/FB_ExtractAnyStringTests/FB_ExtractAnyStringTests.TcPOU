testNeg02_NoSufixFound_EmptyStringNoDataCahnge();
testNeg03_NoPrefixFound_EmptyStringNoDataCahnge();
testNeg04_NoPrefixSufixFoundNoCharsExtr_LeftString();
testNeg05_PrefixFoundNoSufixNoCharsExtr_RightString();

//==============================================================
