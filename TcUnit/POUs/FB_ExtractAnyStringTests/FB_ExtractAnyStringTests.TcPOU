    <Method Name="testMain07_ExtractFromLongString_ExtractData" Id="{37e983f7-6f7e-41d3-b056-f4ef2715900c}" FolderPath="01 Main\">
      <Declaration><![CDATA[METHOD INTERNAL testMain07_ExtractFromLongString_ExtractData
VAR
	fbSut 			: EXTRACT.FB_ExtractAnyString;
	sResult 		: T_LongSTRING;	// Result
END_VAR
VAR_INST
	aDataString		: ARRAY[1..3] OF T_LongSTRING;
END_VAR

// '$01ST=53;$02CT=10;DS=GZDNP5JOA3IL;OG=3;XP=-50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=1;$03$04
//		$01ST=53;$02CT=10;DS=N7E1Y89UNK3O;OG=3;XP=-50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=2;$03$04
//		$01ST=53;$02CT=10;DS=JHWJXYFNX9DS;OG=3;XP=50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=3;$03$04
//		$01ST=53;$02CT=10;DS=XGBEZLBV8A9I;OG=3;XP=50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=4;$03$04'; ]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('testMain07_ExtractFromLongString_ExtractData');	
			
aDataString[1] := '$01ST=53;$02CT=10;DS=GZDNP5JOA3IL;OG=3;XP=-50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=1;$03$04
					$01ST=53;$02CT=10;DS=N7E1Y89UNK3O;OG=3;XP=-50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=2;$03$04
					$01ST=53;$02CT=10;DS=JHWJXYFNX9DS;OG=3;XP=50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=3;$03$04
					$01ST=53;$02CT=10;DS=XGBEZLBV8A9I;OG=3;XP=50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=4;$03$04'; 
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=9 , 
	sPrefix:='XGB' , 
	sSuffix:= '', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHIDENT, 
	sDataString:= aDataString[1], 
	bStringFound=> , 
	sExtractedString=>sResult, 
	nExtractedStringPos=> ,
	nExtractedStringLen=> ,
	nDataStringLen=> );
	
	
	AssertEquals_STRING(	Expected:= 'XGBEZLBV8A9I', 
						Actual:= sResult, 
						Message:= 'Extr data in mode:WITHIDENT not as expect');
	
aDataString[2] := '$01ST=53;$02CT=10;DS=GZDNP5JOA3IL;OG=3;XP=-50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=1;$03$04
					$01ST=53;$02CT=10;DS=N7E1Y89UNK3O;OG=3;XP=-50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=2;$03$04
					$01ST=53;$02CT=10;DS=JHWJXYFNX9DS;OG=3;XP=50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=3;$03$04
					$01ST=53;$02CT=10;DS=XGBEZLBV8A9I;OG=3;XP=50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=4;$03$04'; 
					
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:='DS=' , 
	sSuffix:= ';OG', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_PURGE, 
	sDataString:= aDataString[2], 
	bStringFound=> , 
	sExtractedString=>sResult, 
	nExtractedStringPos=> ,
	nExtractedStringLen=> ,
	nDataStringLen=> );
	
	
	AssertEquals_STRING(	Expected:= 'GZDNP5JOA3IL', 
						Actual:= sResult, 
						Message:= 'Extr data in mode:WITHOUTIDENT_PURGE not as expect');
				
TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="testMain08_ExtractFromLongString_LenghtExtractedDataOk" Id="{5ecddccd-0778-448b-a0f7-0d84ba408cb7}" FolderPath="01 Main\">
      <Declaration><![CDATA[METHOD INTERNAL testMain08_ExtractFromLongString_LenghtExtractedDataOk
VAR
	fbSut 			: EXTRACT.FB_ExtractAnyString;
	nResult 		: UDINT;	// Result
END_VAR
VAR_INST
	aDataString		: ARRAY[1..4] OF T_LongSTRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('testMain08_ExtractFromLongString_LenghtExtractedDataOk');	
			
aDataString[1] := '$01ST=53;$02CT=10;DS=GZDNP5JOA3IL;OG=3;XP=-50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=1;$03$04
					$01ST=53;$02CT=10;DS=N7E1Y89UNK3O;OG=3;XP=-50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=2;$03$04
					$01ST=53;$02CT=10;DS=JHWJXYFNX9DS;OG=3;XP=50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=3;$03$04
					$01ST=53;$02CT=10;DS=XGBEZLBV8A9I;OG=3;XP=50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=4;$03$04'; 
					
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:='$01' , 
	sSuffix:= '$04', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHIDENT, 
	sDataString:= aDataString[1], 
	bStringFound=> , 
	sExtractedString=>, 
	nExtractedStringPos=> ,
	nExtractedStringLen=>nResult ,
	nDataStringLen=> );
	
	
	AssertEquals_UDINT(	Expected:= 83, 
						Actual:= nResult, 
						Message:= 'Extr data in mode:WITHIDENT not as expect');
				
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:='$01' , 
	sSuffix:= '$04', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHIDENT, 
	sDataString:= aDataString[1], 
	bStringFound=> , 
	sExtractedString=>, 
	nExtractedStringPos=> ,
	nExtractedStringLen=>nResult ,
	nDataStringLen=> );
	
	
	AssertEquals_UDINT(	Expected:= 84, 
						Actual:= nResult, 
						Message:= 'Extr data in mode:WITHIDENT not as expect');
						
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:='$01' , 
	sSuffix:= '$04', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHIDENT, 
	sDataString:= aDataString[1], 
	bStringFound=> , 
	sExtractedString=>, 
	nExtractedStringPos=> ,
	nExtractedStringLen=>nResult ,
	nDataStringLen=> );
	
	
	AssertEquals_UDINT(	Expected:= 82, 
						Actual:= nResult, 
						Message:= 'Extr data in mode:WITHIDENT not as expect');
						
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:='$01' , 
	sSuffix:= '$04', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHIDENT, 
	sDataString:= aDataString[1], 
	bStringFound=> , 
	sExtractedString=>, 
	nExtractedStringPos=> ,
	nExtractedStringLen=>nResult ,
	nDataStringLen=> );
	
	
	AssertEquals_UDINT(	Expected:= 83, 
						Actual:= nResult, 
						Message:= 'Extr data in mode:WITHIDENT not as expect');
				
TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="testMain09_ExtractCharOnly_LeftStringWithExtractCharLenght" Id="{c07e72e2-84e2-41b1-a2f0-c8bd9e7fd331}" FolderPath="01 Main\">
      <Declaration><![CDATA[METHOD INTERNAL testMain09_ExtractCharOnly_LeftStringWithExtractCharLenght
VAR
	fbSut 			: EXTRACT.FB_ExtractAnyString;
	nResult 		: UDINT;	// Result
END_VAR
VAR_INST
	aDataString		: ARRAY[1..4] OF T_LongSTRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('testMain09_ExtractCharOnly_LeftStringWithExtractCharLenght');	
			
aDataString[1] := '$01ST=53;$02CT=10;DS=GZDNP5JOA3IL;OG=3;XP=-50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=1;$03$04$01ST=53;$02CT=10;DS=N7E1Y89UNK3O;OG=3;XP=-50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=2;$03$04'; 
					
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=82 , 
	sPrefix:='$01' , 
	sSuffix:= '$04', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHIDENT, 
	sDataString:= aDataString[1], 
	bStringFound=> , 
	sExtractedString=>, 
	nExtractedStringPos=> ,
	nExtractedStringLen=>nResult ,
	nDataStringLen=> );
	
	AssertEquals_STRING(Expected:= '$01ST=53;$02CT=10;DS=GZDNP5JOA3IL;OG=3;XP=-50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=1;$03$04', 
						Actual:= fbSut.sExtractedString, 
						Message:= 'Extr string in mode:WITHIDENT not as expect');
						
	AssertEquals_STRING(Expected:= '$01ST=53;$02CT=10;DS=N7E1Y89UNK3O;OG=3;XP=-50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=2;$03$04', 
						Actual:= aDataString[1], 
						Message:= 'Remain string in mode:WITHIDENT not as expect');
						
	AssertEquals_UDINT(	Expected:= 83, 
						Actual:= fbSut.nExtractedStringLen, 
						Message:= 'Extr data in mode:WITHIDENT not as expect');
				
	
TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="testNeg01_ReverseIdentAllModes_EmptyString" Id="{237b012e-8917-4ec9-a5d3-865b5b7594e4}" FolderPath="02 Negative\">
      <Declaration><![CDATA[METHOD INTERNAL testNeg01_ReverseIdentAllModes_EmptyString
VAR_INST
	fbSut 			: EXTRACT.FB_ExtractAnyString;
	aDataString		: ARRAY[1..6] OF T_LongSTRING;
	sResult 		: T_LongSTRING;	// Result
END_VAR

// '$01ST=53;$02CT=10;DS=]d201062533414058582101485MV125000156300$1D24010120957;OG=3;XP=94;YP=-39;AP=-88;CS=06.2;SC=0070;PN=1;QS=3;$03$04'; ]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('testNeg01_ReverseIdentAllModes_EmptyString');

aDataString[1] := '$01ST=53;$02CT=10;DS=]d201062533414058582101485MV125000156300$1D24010120957;OG=3;XP=94;YP=-39;AP=-88;CS=06.2;SC=0070;PN=1;QS=3;$03$04'; 
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:=';OG' , 
	sSuffix:= 'DS=', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHIDENT, 
	sDataString:= aDataString[1], 
	bStringFound=> , 
	sExtractedString=>sResult, 
	nExtractedStringPos=> ,
	nExtractedStringLen=> ,
	nDataStringLen=> );
	
	
	AssertEquals_STRING(	Expected:= '', 
						Actual:= sResult, 
						Message:= 'Extr data in mode:WITHIDENT not as expect');
						
	AssertEquals_STRING(	Expected:= '$01ST=53;$02CT=10;DS=]d201062533414058582101485MV125000156300$1D24010120957;OG=3;XP=94;YP=-39;AP=-88;CS=06.2;SC=0070;PN=1;QS=3;$03$04', 
						Actual:= aDataString[1], 
						Message:= 'Remaining string 1 is not as expected');
			
aDataString[2] := '$01ST=53;$02CT=10;DS=]d201062533414058582101485MV125000156300$1D24010120957;OG=3;XP=94;YP=-39;AP=-88;CS=06.2;SC=0070;PN=1;QS=3;$03$04'; 
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:=';OG' , 
	sSuffix:= 'DS=', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHIDENT_PURGE, 
	sDataString:= aDataString[2], 
	bStringFound=> , 
	sExtractedString=>sResult, 
	nExtractedStringPos=> ,
	nExtractedStringLen=> ,
	nDataStringLen=> );
	
	
	AssertEquals_STRING(	Expected:= '', 
						Actual:= sResult, 
						Message:= 'Extr data in mode:WITHIDENT_PURGE not as expect');
						
	AssertEquals_STRING(	Expected:= '$01ST=53;$02CT=10;DS=]d201062533414058582101485MV125000156300$1D24010120957;OG=3;XP=94;YP=-39;AP=-88;CS=06.2;SC=0070;PN=1;QS=3;$03$04', 
						Actual:= aDataString[2], 
						Message:= 'Remaining string 2 is not as expected');
						
			
aDataString[3] := '$01ST=53;$02CT=10;DS=]d201062533414058582101485MV125000156300$1D24010120957;OG=3;XP=94;YP=-39;AP=-88;CS=06.2;SC=0070;PN=1;QS=3;$03$04'; 
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:=';OG' , 
	sSuffix:= 'DS=', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT, 
	sDataString:= aDataString[3], 
	bStringFound=> , 
	sExtractedString=>sResult, 
	nExtractedStringPos=> ,
	nExtractedStringLen=> ,
	nDataStringLen=> );
	
	
	AssertEquals_STRING(	Expected:= '', 
						Actual:= sResult, 
						Message:= 'Extr data in mode:WITHOUTIDENT not as expect');
						
	AssertEquals_STRING(	Expected:= '$01ST=53;$02CT=10;DS=]d201062533414058582101485MV125000156300$1D24010120957;OG=3;XP=94;YP=-39;AP=-88;CS=06.2;SC=0070;PN=1;QS=3;$03$04', 
						Actual:= aDataString[3], 
						Message:= 'Remaining string 3 is not as expected');
						
			
aDataString[4] := '$01ST=53;$02CT=10;DS=]d201062533414058582101485MV125000156300$1D24010120957;OG=3;XP=94;YP=-39;AP=-88;CS=06.2;SC=0070;PN=1;QS=3;$03$04'; 
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:=';OG' , 
	sSuffix:= 'DS=', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_PURGE, 
	sDataString:= aDataString[4], 
	bStringFound=> , 
	sExtractedString=>sResult, 
	nExtractedStringPos=> ,
	nExtractedStringLen=> ,
	nDataStringLen=> );
	
	
	AssertEquals_STRING(	Expected:= '', 
						Actual:= sResult, 
						Message:= 'Extr data in mode:WITHOUTIDENT_PURGE not as expect');
						
	AssertEquals_STRING(	Expected:= '$01ST=53;$02CT=10;DS=]d201062533414058582101485MV125000156300$1D24010120957;OG=3;XP=94;YP=-39;AP=-88;CS=06.2;SC=0070;PN=1;QS=3;$03$04', 
						Actual:= aDataString[4], 
						Message:= 'Remaining string 4 is not as expected');
						
			
aDataString[5] := '$01ST=53;$02CT=10;DS=]d201062533414058582101485MV125000156300$1D24010120957;OG=3;XP=94;YP=-39;AP=-88;CS=06.2;SC=0070;PN=1;QS=3;$03$04'; 
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:=';OG' , 
	sSuffix:= 'DS=', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_REMIDENT, 
	sDataString:= aDataString[5], 
	bStringFound=> , 
	sExtractedString=>sResult, 
	nExtractedStringPos=> ,
	nExtractedStringLen=> ,
	nDataStringLen=> );
	
	
	AssertEquals_STRING(	Expected:= '', 
						Actual:= sResult, 
						Message:= 'Extr data in mode:WITHOUTIDENT_REMIDENT not as expect');
						
	AssertEquals_STRING(	Expected:= '$01ST=53;$02CT=10;DS=]d201062533414058582101485MV125000156300$1D24010120957;OG=3;XP=94;YP=-39;AP=-88;CS=06.2;SC=0070;PN=1;QS=3;$03$04', 
						Actual:= aDataString[5], 
						Message:= 'Remaining string 5 is not as expected');
						
			
aDataString[6] := '$01ST=53;$02CT=10;DS=]d201062533414058582101485MV125000156300$1D24010120957;OG=3;XP=94;YP=-39;AP=-88;CS=06.2;SC=0070;PN=1;QS=3;$03$04'; 
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:=';OG' , 
	sSuffix:= 'DS=', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_REMIDENT_PURGE, 
	sDataString:= aDataString[6], 
	bStringFound=> , 
	sExtractedString=>sResult, 
	nExtractedStringPos=> ,
	nExtractedStringLen=> ,
	nDataStringLen=> );
	
	
	AssertEquals_STRING(	Expected:= '', 
						Actual:= sResult, 
						Message:= 'Extr data in mode:WITHOUTIDENT_REMIDENT_PURGE not as expect');
						
	AssertEquals_STRING(	Expected:= '$01ST=53;$02CT=10;DS=]d201062533414058582101485MV125000156300$1D24010120957;OG=3;XP=94;YP=-39;AP=-88;CS=06.2;SC=0070;PN=1;QS=3;$03$04', 
						Actual:= aDataString[6], 
						Message:= 'Remaining string 6 is not as expected');
				
TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="testNeg02_NoSufixFound_EmptyStringNoDataCahnge" Id="{abec52e3-c6f6-4cb1-bddb-30c9763ab919}" FolderPath="02 Negative\">
      <Declaration><![CDATA[METHOD INTERNAL testNeg02_NoSufixFound_EmptyStringNoDataCahnge
VAR
	fbSut 			: EXTRACT.FB_ExtractAnyString;
	sResult			: T_LongSTRING;	// Result
	nResult 		: UDINT;	// Result
	nDataResult		: UDINT;
	
	nDataOrigin	: UDINT;
END_VAR
VAR_INST
	sDataString		: T_LongSTRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('testNeg02_NoSufixFound_EmptyStringNoDataCahnge');	
			
sDataString := '$01ST=53;$02CT=10;DS=GZDNP5JOA3IL;OG=3;XP=-50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=1;$03
					$01ST=53;$02CT=10;DS=N7E1Y89UNK3O;OG=3;XP=-50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=2;$03
					$01ST=53;$02CT=10;DS=JHWJXYFNX9DS;OG=3;XP=50;YP=50;AP=-88;CS=06.2;SC=0070;QS=3;PN=3;$03
					$01ST=53;$02CT=10;DS=XGBEZLBV8A9I;OG=3;XP=50;YP=-50;AP=-88;CS=06.2;SC=0070;QS=3;PN=4;$03'; 

nDataOrigin	:= len2(ADR(sDataString));
					
fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:='$01' , 
	sSuffix:= '$04', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHIDENT, 
	sDataString:= sDataString, 
	bStringFound=> , 
	sExtractedString=>sResult, 
	nExtractedStringPos=> ,
	nExtractedStringLen=>nResult ,
	nDataStringLen=>nDataResult );
	
	AssertEquals_STRING(	Expected:= '', 
						Actual:= sResult, 
						Message:= 'Extracted string is not as expected');
						
	AssertEquals_UDINT(	Expected:= 0, 
						Actual:= nResult, 
						Message:= 'Extr data in mode:WITHIDENT not as expect');
						
	AssertEquals_UDINT(	Expected:= nDataOrigin, 
						Actual:= nDataResult, 
						Message:= 'Left data in mode:WITHIDENT not as expect');
						
TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="testNeg03_NoPrefixFound_EmptyStringNoDataCahnge" Id="{c1e87807-420f-4b83-b37f-5c8be0ed386b}" FolderPath="02 Negative\">
