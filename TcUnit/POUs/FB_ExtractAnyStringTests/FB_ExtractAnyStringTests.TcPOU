testSeq01_MVxDecode_ImageData();

//==============================================================
//OTHERS TESTS
//==============================================================

//FbExtrctAnyStringTests_ExtractPrefLenght_StringExtracted();
//FbExtrctAnyStringTests_ExtractPrefLenghtToLong_EmptyString();]]></ST>
