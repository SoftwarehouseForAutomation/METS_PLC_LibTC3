    <Folder Name="01 Main" Id="{37a70e98-012a-4364-beda-fba88cc0bec8}" />
    <Folder Name="02 Negative" Id="{c13f098a-efa4-412d-a3b6-60a61835f972}" />
    <Folder Name="03 Sequence" Id="{fbd25f82-e2f0-46b2-8178-ebf554e3b92a}" />
    <Folder Name="99 Others" Id="{15b2a496-6670-4d1f-ba1a-35bf3bebc183}" />
    <Method Name="FbExtrctAnyStringTests_ExtractPrefLenght_StringExtracted" Id="{41f27568-4085-4ce9-b4f0-cb52823bc80c}" FolderPath="99 Others\">
      <Declaration><![CDATA[METHOD INTERNAL FbExtrctAnyStringTests_ExtractPrefLenght_StringExtracted 
VAR_INST
	fbSut 	: EXTRACT.FB_ExtractAnyString;
	sDataString		: T_LongSTRING := 'ABCDEFGHIJKL'; 
	sResult : T_LongSTRING;	// Result
END_VAR
//FB_ExtractAnyString]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('FbExtrctAnyStringTests_ExtractPrefLenght_StringExtracted');

fbSut(
	bExtractData:= TRUE, 
	nExtractChars:= 3 , 
	sPrefix:='E' , 
	sSuffix:= '', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_PURGE, 
	sDataString:= sDataString, 
	bStringFound=> , 
	sExtractedString=>sResult, 
	nExtractedStringPos=> ,
	nExtractedStringLen=> ,
	nDataStringLen=> );
	
	
	AssertEquals_STRING(	Expected:= 'FGH', 
						Actual:= fbSut.sExtractedString, 
						Message:= 'Extracted string is not as expected');
						
	AssertEquals_STRING(	Expected:= 'IJKL', 
						Actual:= sDataString, 
						Message:= 'Remaining string is not as expected');
						
TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="FbExtrctAnyStringTests_ExtractPrefLenghtToLong_EmptyString" Id="{fc584bdf-37dd-430a-ba51-7956d8f79883}" FolderPath="99 Others\">
      <Declaration><![CDATA[METHOD INTERNAL FbExtrctAnyStringTests_ExtractPrefLenghtToLong_EmptyString 
VAR_INST
	fbSut 	: EXTRACT.FB_ExtractAnyString;
	sDataString		: T_LongSTRING := 'ABCDEFGHIJKL'; 
	sResult : T_LongSTRING;	// Result
END_VAR
//FB_ExtractAnyString]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('FbExtrctAnyStringTests_ExtractPrefLenghtToLong_EmptyString');

fbSut(
	bExtractData:= TRUE, 
	nExtractChars:= 15 , 
	sPrefix:='B' , 
	sSuffix:= '', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHOUTIDENT_PURGE, 
	sDataString:= sDataString, 
	bStringFound=> , 
	sExtractedString=>sResult, 
	nExtractedStringPos=> ,
	nExtractedStringLen=> ,
	nDataStringLen=> );
	
	
	AssertEquals_STRING(	Expected:= 'CDEFGHIJKL', 
						Actual:= fbSut.sExtractedString, 
						Message:= 'Extracted string is not as expected');
						
	AssertEquals_STRING(	Expected:= '', 
						Actual:= sDataString, 
						Message:= 'Remaining string is not as expected');
						
TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="testMain01_ModeWITHIDENT_ExactDataNoPurge" Id="{e0a16af1-7734-4057-a1e8-d9abaef476cb}" FolderPath="01 Main\">
      <Declaration><![CDATA[METHOD INTERNAL testMain01_ModeWITHIDENT_ExactDataNoPurge
VAR
	fbSut 			: EXTRACT.FB_ExtractAnyString;
	sDataString		: T_LongSTRING := '$01ST=53;$02CT=10;DS=]d201062533414058582101485MV125000156300$1D24010120957;OG=3;XP=94;YP=-39;AP=-88;CS=06.2;SC=0070;PN=1;QS=3;$03$04'; 
	sResult 		: T_LongSTRING;	// Result
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[TEST('testMain01_ModeWITHIDENT_ExactDataNoPurge');

fbSut(
	bExtractData:= TRUE, 
	nExtractChars:=0 , 
	sPrefix:='DS=' , 
	sSuffix:= ';OG', 
	bIgnoreCase:= FALSE, 
	eExtractMode := EXTRACT.E_ExtrMode.WITHIDENT, 
	sDataString:= sDataString, 
	bStringFound=> , 
	sExtractedString=>sResult, 
	nExtractedStringPos=> ,
	nExtractedStringLen=> ,
	nDataStringLen=> );
	
	
	AssertEquals_STRING(	Expected:= 'DS=]d201062533414058582101485MV125000156300$1D24010120957;OG', 
						Actual:= sResult, 
						Message:= 'Extracted string is not as expected');
						
	AssertEquals_STRING(	Expected:= '$01ST=53;$02CT=10;=3;XP=94;YP=-39;AP=-88;CS=06.2;SC=0070;PN=1;QS=3;$03$04', 
						Actual:= sDataString, 
						Message:= 'Remaining string is not as expected');
						
TEST_FINISHED();]]></ST>
      </Implementation>
    </Method>
    <Method Name="testMain02_ModeWITHIDENTPURGE_ExactDataAndPurge" Id="{098da410-317b-4d13-8025-f13f3380ecce}" FolderPath="01 Main\">
      <Declaration><![CDATA[METHOD INTERNAL testMain02_ModeWITHIDENTPURGE_ExactDataAndPurge
